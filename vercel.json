{
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/dist",
  "framework": "react",
  "installCommand": "cd web && npm install",
  "rootDirectory": ".",
  "functions": {
    "web/api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "web/api/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/web/dist/index.html",
      "status": 200
    }
  ]
}