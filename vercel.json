{
  "version": 2,
  "installCommand": "cd web && npm install",
  "buildCommand": "cd web && npm run build",
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/$1.js"
    },
    {
      "src": "^(?!/api/).*",
      "dest": "web/dist/index.html"
    }
  ]
}